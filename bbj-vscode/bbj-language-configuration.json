{
    "comments": {
        "lineComment": "REM"
    },
    "wordPattern": "(-?\\d*\\.\\d\\w*)|(#?[A-Za-z_][A-Za-z0-9_]*[!$%@]?)",
    "brackets": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ]
    ],
    "autoClosingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "\"",
            "\""
        ],
        [
            "'",
            "'"
        ],
        {
            "open": "REM /**",
            "close": "REM  */",
            "notIn": [
                "string"
            ]
        },
        {
            "open": "rem /**",
            "close": "rem  */",
            "notIn": [
                "string"
            ]
        },
    ],
    "surroundingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "\"",
            "\""
        ],
        [
            "'",
            "'"
        ]
    ],
    "onEnterRules": [
        {
            "beforeText": "^\\s*[Rr][Ee][Mm]\\s*\\/\\*\\*(?!\\/)([^\\*]|\\*(?!\\/))*$",
            "action": {
                "indent": "indentOutdent",
                "appendText": "REM  * "
            }
        },
        {
            "beforeText": "^\\s*[Rr][Ee][Mm]\\s*\\*[^\\/].*$",
            "action": {
                "indent": "none",
                "appendText": "REM  * "
            }
        },
        {
            "beforeText": "^\\s*[Rr][Ee][Mm][^\\*]$",
            "action": {
                "indent": "none",
                "appendText": "REM "
            }
        }
    ],
}